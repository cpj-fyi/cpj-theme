{{!< default}}

{{!--
    Everything archive
    All posts, year-grouped, most recent first.
    Year groupings + jump-nav are built by initEverything() in main.js.
--}}

<div class="archive-layout archive-layout-everything">
    <header class="archive-header">
        <h1 class="archive-title">Everything</h1>
        <p class="archive-description">All posts, most recent first. Going back 20 years!</p>
    </header>

    <nav class="archive-year-nav" id="archive-year-nav" aria-label="Jump to year"></nav>

    <div class="archive-list" id="archive-list">
        {{!-- Paginated to bypass any internal {{#get}} cap on limit="all".
             Ghost's Handlebars helper has been observed capping ~100 posts. --}}
        {{#get "posts" limit="100" page="1" order="published_at desc" include="tags,authors"}}
            {{#foreach posts}}
                {{> "archive-item"}}
            {{/foreach}}
        {{/get}}
        {{#get "posts" limit="100" page="2" order="published_at desc" include="tags,authors"}}
            {{#foreach posts}}
                {{> "archive-item"}}
            {{/foreach}}
        {{/get}}
        {{#get "posts" limit="100" page="3" order="published_at desc" include="tags,authors"}}
            {{#foreach posts}}
                {{> "archive-item"}}
            {{/foreach}}
        {{/get}}
        {{#get "posts" limit="100" page="4" order="published_at desc" include="tags,authors"}}
            {{#foreach posts}}
                {{> "archive-item"}}
            {{/foreach}}
        {{/get}}
        {{#get "posts" limit="100" page="5" order="published_at desc" include="tags,authors"}}
            {{#foreach posts}}
                {{> "archive-item"}}
            {{/foreach}}
        {{/get}}
    </div>
</div>
