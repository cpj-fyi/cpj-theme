<!DOCTYPE html>
<html lang="{{@site.locale}}">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>

    <link rel="stylesheet" href="https://use.typekit.net/YOUR_TYPEKIT_ID.css">
    <link rel="stylesheet" href="{{asset "css/screen.css"}}">
    <link rel="stylesheet" href="{{asset "css/buy-page.css"}}">
    <link rel="stylesheet" href="{{asset "css/contact-form.css"}}">

    {{ghost_head}}
    {{!-- monafor/art OG image fallback for posts without a feature_image --}}
    {{#is "post"}}
        {{#unless feature_image}}
            <meta property="og:image" content="{{@custom.art_url}}/{{slug}}.svg">
            <meta name="twitter:image" content="{{@custom.art_url}}/{{slug}}.svg">
        {{/unless}}
    {{/is}}
</head>
<body class="{{body_class}}">
    <div class="site-wrapper">
        {{> "header"}}

        <main class="site-main">
            {{{body}}}
        </main>

        {{> "footer"}}
    </div>

    {{> "search-modal"}}

    <script src="{{asset "js/main.js"}}"></script>
    <script src="{{asset "js/buy-page.js"}}"></script>
    {{ghost_foot}}
</body>
</html>
