{{!--
    Search modal — opens via Cmd+K (Mac) / Ctrl+K (Win/Linux) or the
    header search button. Powered by Pagefind, which loads its own
    index from the configured base URL on first open.
--}}
<div class="search-modal" id="search-modal" hidden>
    <div class="search-modal-backdrop" data-search-close></div>
    <div class="search-modal-panel" role="dialog" aria-modal="true" aria-label="Search">
        <form class="search-modal-form" autocomplete="off" onsubmit="return false;">
            <span class="search-modal-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </span>
            <input type="search" id="search-input" class="search-modal-input"
                   placeholder="Search posts and chapters…" autocomplete="off"
                   spellcheck="false" aria-label="Search posts and chapters">
            <button type="button" class="search-modal-close" data-search-close
                    aria-label="Close search">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </form>

        <div class="search-modal-results" id="search-results">
            <p class="search-modal-empty">Type to search posts, essays, and chapters.</p>
        </div>

        <div class="search-modal-footer">
            <span class="search-modal-hint"><kbd>↑↓</kbd> navigate</span>
            <span class="search-modal-hint"><kbd>↵</kbd> open</span>
            <span class="search-modal-hint"><kbd>Esc</kbd> close</span>
        </div>
    </div>
</div>
