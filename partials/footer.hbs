<footer class="site-footer">
    <div class="container">
        <div class="footer-main">
            <div class="footer-book">
                <div class="footer-book-label">The Book</div>
                <h3 class="footer-book-title">{{@custom.book_title}}</h3>
                <div class="footer-book-author">by {{@custom.book_author}}</div>
                <p class="footer-book-description">{{@custom.book_description}}</p>
                <a href="https://cpj.fyi/buy" class="btn btn-primary">Get the Book</a>
            </div>

            <div class="footer-column">
                <h4>Book Sections</h4>
                <ul>
                    <li><a href="{{@site.url}}/tag/start-end/">Start & End</a></li>
                    <li><a href="{{@site.url}}/tag/foundations/">Foundations</a></li>
                    <li><a href="{{@site.url}}/tag/structuring/">Structuring</a></li>
                    <li><a href="{{@site.url}}/tag/direction/">Direction</a></li>
                    <li><a href="{{@site.url}}/tag/practice/">Practice</a></li>
                    <li><a href="{{@site.url}}/tag/learning/">Learning</a></li>
                    <li><a href="{{@site.url}}/tag/space/">Space</a></li>
                </ul>
            </div>

            <div class="footer-column">
                <h4>Site Content</h4>
                <ul>
                    <li><a href="{{@site.url}}/essays/">Essays</a></li>
                    <li><a href="{{@site.url}}/five-things/">Five Things</a></li>
                    <li><a href="{{@site.url}}/radar/">Radar</a></li>
                </ul>
            </div>

            {{#if @site.navigation}}
            <div class="footer-column">
                <h4>About</h4>
                <ul>
                    {{#foreach @site.navigation}}
                        <li><a href="{{this.url}}">{{this.label}}</a></li>
                    {{/foreach}}
                </ul>
            </div>
            {{/if}}

            {{#if @site.secondary_navigation}}
            <div class="footer-column">
                <h4>Elsewhere</h4>
                <ul>
                    {{#foreach @site.secondary_navigation}}
                        <li><a href="{{this.url}}">{{this.label}}</a></li>
                    {{/foreach}}
                </ul>
            </div>
            {{/if}}
        </div>
    </div>

    <div class="footer-gradient">
        <div class="container">

        <div class="footer-readby">
            <div class="footer-readby-head">
                <span class="footer-readby-eyebrow">Read by</span>
                <span class="footer-readby-rule" aria-hidden="true"></span>
                <span class="footer-readby-count">
                    <span class="footer-readby-count-num">1,000+</span>
                    <span class="footer-readby-count-label">subscribers &amp; counting</span>
                </span>
            </div>
            <ul class="footer-readby-logos">
                <li><img src="{{asset "images/logos/airbnb.svg"}}" alt="Airbnb"></li>
                <li><img src="{{asset "images/logos/apple.svg"}}" alt="Apple"></li>
                <li><img src="{{asset "images/logos/google.svg"}}" alt="Google"></li>
                <li><img src="{{asset "images/logos/anthropic.svg"}}" alt="Anthropic"></li>
                <li><img src="{{asset "images/logos/atlassian.svg"}}" alt="Atlassian"></li>
                <li><img src="{{asset "images/logos/miro.svg"}}" alt="Miro"></li>
                <li><img src="{{asset "images/logos/etsy.svg"}}" alt="Etsy"></li>
                <li><img src="{{asset "images/logos/ideo.svg"}}" alt="IDEO"></li>
                <li><img src="{{asset "images/logos/wieden-kennedy.svg"}}" alt="Wieden+Kennedy"></li>
                <li><img src="{{asset "images/logos/marriott.svg"}}" alt="Marriott"></li>
                <li><img src="{{asset "images/logos/pepsico.svg"}}" alt="PepsiCo"></li>
                <li><img src="{{asset "images/logos/bayer.svg"}}" alt="Bayer"></li>
                <li><img src="{{asset "images/logos/boeing.svg"}}" alt="Boeing"></li>
                <li><img src="{{asset "images/logos/new-school.svg"}}" alt="The New School"></li>
                <li><img src="{{asset "images/logos/sandia.svg"}}" alt="Sandia National Labs"></li>
                <li><img src="{{asset "images/logos/nhs.svg"}}" alt="NHS"></li>
            </ul>
        </div>

        <div class="footer-actions">
            {{#if @member}}
                <a href="#/portal/account" class="btn btn-primary">Account Settings</a>
            {{else}}
                <a href="#/portal/signup" class="btn btn-primary">Subscribe</a>
            {{/if}}
            <a href="/contact/" class="btn btn-contact">Contact</a>
        </div>

        <div class="footer-bottom">
            <div class="footer-copyright">
                {{> "cyclist-svg"}}
                <span class="footer-copyright-text">&copy; 2006–2026 {{@site.title}}. {{@custom.footer_tagline}}</span>
            </div>
            <div class="footer-powered">
                <a href="https://ghost.org" target="_blank" rel="noopener">Powered by Ghost</a>
            </div>
        </div>

        </div>
    </div>
</footer>
