{{!< default}}

{{!-- Hero banner with author name --}}
<div class="home-hero">
    <div class="container">
        <h1 class="home-hero-name">{{@custom.book_author}}</h1>
        {{#if @site.description}}
            <p class="home-hero-description">{{@site.description}}</p>
        {{/if}}
    </div>
</div>

<div class="container">
    <div class="home-layout">
        {{!-- Left column: Featured (latest) essay --}}
        <div class="home-book home-feature-essay">
            {{#get "posts" filter="tag:essays" limit="1" include="tags"}}
                {{#if posts}}
                    {{#foreach posts}}
                        <div class="essay-feature-label">Latest Essay</div>
                        <a href="{{url}}" class="essay-feature-image-link" aria-hidden="true" tabindex="-1">
                            <img class="essay-feature-image" src="{{#if feature_image}}{{feature_image}}{{else}}{{@custom.art_url}}/{{slug}}.svg{{/if}}" alt="" loading="eager" width="1200" height="630">
                        </a>
                        <h1 class="essay-feature-title">
                            <a href="{{url}}">{{title}}</a>
                        </h1>
                        {{#if custom_excerpt}}
                            <p class="essay-feature-excerpt">{{custom_excerpt}}</p>
                        {{/if}}
                        <div class="essay-feature-preview">
                            {{content words="350"}}
                        </div>
                        <a href="{{url}}" class="essay-feature-link btn btn-primary btn-large">Keep reading →</a>
                    {{/foreach}}
                {{/if}}
            {{/get}}
        </div>

        {{!-- Middle column: Essays --}}
        <section class="home-essays">
            <h2 class="section-title section-title-essays">Essays</h2>

            {{!-- limit=5 + foreach from="2" so we skip the featured essay (latest) and show the next 4 --}}
            {{#get "posts" filter="tag:essays" limit="5" include="tags"}}
                {{#if posts}}
                    <div class="essays-feed">
                        {{#foreach posts from="2"}}
                            <article class="essay-card">
                                <h3 class="essay-card-title">
                                    <a href="{{url}}">{{title}}</a>
                                </h3>
                                <p class="essay-card-excerpt">{{excerpt}}</p>
                                <div class="ds-meta">
                                    <span class="ds-meta-item">{{date format="MM DD YY"}}</span>
                                    {{#foreach tags}}
                                        {{#match slug "essays"}}{{else match slug "radar"}}{{else match slug "five-things"}}{{else match slug "hidden-patterns"}}
                                        {{else}}
                                            <a href="{{url}}" class="ds-meta-item topical-tag-pill">{{name}}</a>
                                        {{/match}}
                                    {{/foreach}}
                                </div>
                            </article>
                        {{/foreach}}
                    </div>
                {{/if}}
            {{/get}}
        </section>

        {{!-- Right column: Five Things --}}
        <section class="home-five-things">
            <h2 class="section-title section-title-five-things">Five Things</h2>

            {{#get "posts" filter="tag:five-things" limit="5" include="tags"}}
                {{#if posts}}
                    <div class="five-things-feed">
                        {{#foreach posts}}
                            <article class="five-things-card">
                                <h3 class="five-things-card-title">
                                    <a href="{{url}}">{{title}}</a>
                                </h3>
                                <p class="five-things-card-excerpt">{{excerpt}}</p>
                            </article>
                        {{/foreach}}
                    </div>
                {{/if}}
            {{/get}}
        </section>
    </div>
</div>

{{!-- Radar section - full width dark mode --}}
<section class="home-radar-section">
    <div class="container">
        <div class="section-header section-header-radar">
            <div class="section-header-content">
                <h2 class="section-title section-title-radar">Radar</h2>
                <p class="section-subtitle">Daily observations on organization design.</p>
            </div>
            <a href="{{@site.url}}/radar/" class="section-link">View all</a>
            <div class="radar-dot"></div>
        </div>

        {{#get "posts" filter="tag:radar" limit="3" include="tags"}}
            {{#if posts}}
                <div class="related-posts-grid">
                    {{#foreach posts}}
                        <article class="post-card post-card-text-only">
                            <h3 class="post-card-title">
                                <a href="{{url}}">{{title}}</a>
                            </h3>
                            <p class="post-card-excerpt">{{excerpt}}</p>
                            <div class="ds-meta">
                                <span class="ds-meta-item">{{date format="MM DD YY"}}</span>
                                {{#foreach tags}}
                                    {{#match slug "essays"}}{{else match slug "radar"}}{{else match slug "five-things"}}{{else match slug "hidden-patterns"}}
                                    {{else}}
                                        <a href="{{url}}" class="ds-meta-item topical-tag-pill">{{name}}</a>
                                    {{/match}}
                                {{/foreach}}
                            </div>
                        </article>
                    {{/foreach}}
                </div>
            {{/if}}
        {{/get}}
    </div>
</section>
